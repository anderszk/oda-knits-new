http://odaknits.no, http://www.odaknits.no {
	redir https://{host}{uri} permanent
}

https://odaknits.no, https://www.odaknits.no {
	encode zstd gzip
	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 5
		}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		# Scoped to what this app actually loads: Stripe Elements/Payment Request Button
		# (card fields, Apple Pay) needs js.stripe.com script + frame + api.stripe.com/
		# m.stripe.* for tokenization and fraud checks. Klarna/Vipps are full-page
		# redirects (window.location), not iframes, so they need no CSP allowance.
		Content-Security-Policy "default-src 'self'; script-src 'self' https://js.stripe.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://api.stripe.com https://m.stripe.com https://m.stripe.network; frame-src https://js.stripe.com https://hooks.stripe.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
	}

	handle /api/* {
		reverse_proxy backend:8000
	}

	handle {
		root * /srv
		route {
			try_files {path} /index.html
			header /assets/* Cache-Control "public, max-age=31536000, immutable"
			header /index.html Cache-Control "no-cache"
			file_server
		}
	}
}
